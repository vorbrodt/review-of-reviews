# Copy this file to .env (same folder) and fill in real values.
# .env is gitignored — never commit real keys.

# A Google Maps API key. For local dev, restrict it (Google Cloud Console ->
# Credentials -> your key -> Application restrictions -> HTTP referrers) to
# http://localhost:5173/* — you'll add your real domain here later when you deploy.
# Needs Places API (New), Maps JavaScript API, and Maps Embed API enabled.
VITE_GOOGLE_MAPS_BROWSER_KEY=

# Leave this as-is for local dev — it's wrangler's default local address.
VITE_WORKER_URL=http://localhost:8787
